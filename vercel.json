{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://movewave-backend-production.up.railway.app/api/:path*"
    },
    {
      "source": "/oauth2/:path*",
      "destination": "https://movewave-backend-production.up.railway.app/oauth2/:path*"
    },
    {
      "source": "/login/oauth2/:path*",
      "destination": "https://movewave-backend-production.up.railway.app/login/oauth2/:path*"
    },
    {
      "source": "/logout",
      "destination": "https://movewave-backend-production.up.railway.app/logout"
    }
  ]
}
